<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.aaron.pilot-triage</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/aaron/Documents/Scripts/lift-triage.sh</string>
    </array>
    <key>StartCalendarInterval</key>
