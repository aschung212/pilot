#!/bin/bash
# Pre-commit hook: runs fast-tier tests before allowing a commit.
# Full suite runs in CI on push. Skippable with: git commit --no-verify

echo "🧪 Running fast tests..."

_PILOT_TEST_MODE=1 bash "$(git rev-parse --show-toplevel)/tests/run-tests.sh" --fast 2>&1

if [ $? -ne 0 ]; then
  echo ""
  echo "❌ Tests failed — commit aborted. Fix the failures or skip with --no-verify."
  exit 1
fi

echo "✅ All fast tests passed."
