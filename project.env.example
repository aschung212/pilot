# Pilot — Project Configuration
# Copy this file to project.env and fill in your values.
# This file is sourced by all pipeline scripts.
# Generate automatically with: ./init.sh

# ── Project ──────────────────────────────────────────────────
PROJECT_NAME="<your-project>"                    # Short name, used in filenames and logs
PROJECT_DESC="<brief description for AI prompts>"
TECH_STACK="<e.g., Vue 3 + TypeScript PWA>"
REPO_PATH="/Users/you/development/<your-project>"
GITHUB_REPO="<username>/<your-project>"
DEFAULT_BRANCH="main"                            # main or master

# ── Issue Tracker ────────────────────────────────────────────
TRACKER_ADAPTER="linear"                         # linear | github | custom
LINEAR_TEAM="<TEAM>"                             # Linear team key (e.g., MAS, ENG)
LINEAR_PROJECT="<your-project>"                  # Linear project name
LINEAR_ORG="<your-org>"                          # Linear org slug (from your URL)

# ── AI Models ────────────────────────────────────────────────
AI_CODE_MODEL="opus"                             # Model for code generation
AI_RESEARCH_MODEL="gemini-2.5-flash"             # Model for web research (discovery)

# ── Review Pipeline (3-layer cross-model) ────────────────────
# L1: mechanical gate — runs per-iteration (fast, cheap)
AI_REVIEW_MODEL_L1="gemini-2.5-flash"
AI_REVIEW_FALLBACK_L1="sonnet"                   # Used if L1 model fails/times out
AI_REVIEW_TIMEOUT_L1=90                          # Seconds before fallback

# L2: architecture review — runs per-PR (thorough)
AI_REVIEW_MODEL_L2="gemini-2.5-pro"
AI_REVIEW_FALLBACK_L2="gemini-2.5-flash"         # Deeper prompt on fallback model
AI_REVIEW_TIMEOUT_L2=120

# L3: self-check — runs per-PR (catches what L1+L2 missed)
AI_REVIEW_MODEL_L3="sonnet"
AI_REVIEW_FALLBACK_L3="haiku"
AI_REVIEW_TIMEOUT_L3=90

# ── Notifications ────────────────────────────────────────────
# Webhook URLs and bot tokens go in ~/.zshenv (never commit secrets)
SLACK_CHANNEL_AUTOMATION=""                      # Channel ID for build notifications
SLACK_CHANNEL_REVIEW=""                          # Channel ID for daily review digest
SLACK_CHANNEL_CHANGELOG=""                       # Channel ID for system changelog

# ── Paths ────────────────────────────────────────────────────
PILOT_DIR=""                                     # Root of this repo (set by init.sh)
OUTPUT_DIR="$HOME/Documents/Claude/outputs"      # Where logs and metrics go
PRODUCT_DECISIONS_FILE=""                        # Optional: path to product decisions doc
PRODUCT_FEATURES_FILE=""                         # Optional: path to product features doc
