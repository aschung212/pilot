# Pilot — Project Configuration
# Copy this file to project.env and fill in your values.
# This file is sourced by all pipeline scripts.

# ── Project ──────────────────────────────────────────────────
PROJECT_NAME="MyApp"
REPO_PATH="/Users/you/development/myapp"
GITHUB_REPO="username/myapp"

# ── Issue Tracker ────────────────────────────────────────────
TRACKER_ADAPTER="linear"          # linear | github | custom
LINEAR_TEAM="TEAM"                # Linear team key (e.g., MAS)
LINEAR_PROJECT="MyApp"            # Linear project name

# ── AI Models ────────────────────────────────────────────────
AI_CODE_MODEL="opus"              # Claude model for code generation
AI_REVIEW_MODEL="sonnet"          # Claude model for adversarial review
AI_RESEARCH_MODEL="gemini-2.5-flash"  # Gemini model for web research

# ── Notifications ────────────────────────────────────────────
SLACK_WEBHOOK_URL=""              # Webhook for build notifications
SLACK_WEBHOOK_CHANGELOG=""        # Webhook for system changelog
SLACK_WEBHOOK_DAILY_REVIEW=""     # Webhook for daily digest

# ── Scheduling ───────────────────────────────────────────────
DISCOVER_DAYS="0,2,4"            # Days to run discovery (0=Sun, 1=Mon, ...)
BUILDER_DAYS="1,2,3,4,5"         # Days to run builder (Mon-Fri)
BUILDER_STOP_TIME="07:00"        # Builder stops at this time

# ── Budget ───────────────────────────────────────────────────
MAX_ITERATIONS_PER_NIGHT=12
MAX_OUTPUT_TOKENS_PER_NIGHT=600000
ITERATION_COOLDOWN=30

# ── Paths (auto-set by init.sh) ──────────────────────────────
PILOT_DIR=""                      # Root of this repo
SCRIPTS_DIR=""                    # $PILOT_DIR/scripts
ADAPTER_DIR=""                    # $PILOT_DIR/adapters
OUTPUT_DIR=""                     # Where logs and metrics go
